<Window x:Class="PR23102_Kucherov_9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск преподавателей" 
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="5" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Фамилия:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                <TextBox x:Name="SearchTextBox" Width="150" Margin="0,0,10,0"/>
                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                <ComboBox x:Name="SortComboBox" Width="200" SelectedIndex="0">
                    <ComboBoxItem Content="По убыванию имени"/>
                    <ComboBoxItem Content="По возрастанию специальности"/>
                </ComboBox>
                <Button x:Name="SearchButton" Content="Поиск" Width="80" Margin="10,0,0,0" 
                        Click="SearchButton_Click" Background="LightBlue"/>
            </StackPanel>
        </Border>

        <!-- DataGrid для результатов -->
        <DataGrid x:Name="LoadData" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="LightGray"/>
    </Grid>
</Window>